# =============================================================
# Deadline Guardian AI — Backend Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# =============================================================

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database (Supabase PostgreSQL + Prisma) ──────────────────
# Runtime queries: Supabase connection pooler (Transaction Mode, port 6543)
# Find your pooler host in: Supabase Dashboard → Settings → Database → Connection Pooling
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Migrations only: Supabase direct connection (port 5432)
# Used exclusively by `prisma migrate dev` and `prisma db push`
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres"

# ── AI ────────────────────────────────────────────────────────
GEMINI_API_KEY=your_google_ai_studio_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── CORS ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────
# General API: requests per window
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# AI endpoints: per minute
AI_RATE_LIMIT_MAX=20

# ── AI Behaviour ─────────────────────────────────────────────
MAX_RETRIES=3
