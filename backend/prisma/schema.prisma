// ─────────────────────────────────────────────────────────────
// Phase 4: Goals & Habits & Calendar & Insights & Settings
// ─────────────────────────────────────────────────────────────

model Goal {
  id             String     @id @default(cuid())
  title          String
  description    String?
  type           GoalType   @default(SHORT_TERM)
  status         GoalStatus @default(ACTIVE)
  progress       Int        @default(0)   // 0-100 percent
  targetDate     DateTime?
  linkedTaskIds  Json       @default("[]") // string[]
  aiEstimation   String?    // AI completion estimation text
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([status])
  @@map("goals")
}

model Habit {
  id                String         @id @default(cuid())
  name              String
  description       String?
  frequency         HabitFrequency @default(DAILY)
  streakCount       Int            @default(0)
  completedToday    Boolean        @default(false)
  lastCompletedAt   DateTime?
  completionHistory Json           @default("[]") // { date: string; completed: boolean }[]
  aiSuggestion      String?        // AI-generated tip for this habit
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([frequency])
  @@map("habits")
}

model CalendarEvent {
  id          String            @id @default(cuid())
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  taskId      String?           // Optional link to a Task
  habitId     String?           // Optional link to a Habit
  type        CalendarEventType @default(TASK_BLOCK)
  source      String            @default("INTERNAL") // INTERNAL | GOOGLE | OUTLOOK
  isBlocked   Boolean           @default(false)
  color       String?           // Optional display color hex
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([startAt, endAt])
  @@map("calendar_events")
}

model UserInsight {
  id          String      @id @default(cuid())
  type        InsightType
  title       String
  content     String      // Human-readable insight text
  data        Json        @default("{}") // Structured metrics
  period      String?     // e.g. "2024-W26" or "2024-06"
  generatedAt DateTime    @default(now())

  @@index([type, generatedAt])
  @@map("user_insights")
}

model UserSettings {
  id                       String   @id @default("default")
  workStartHour            Int      @default(9)   // 9 AM
  workEndHour              Int      @default(18)  // 6 PM
  breakDurationMinutes     Int      @default(15)
  focusIntervalMinutes     Int      @default(50)  // Pomodoro default
  emergencyThresholdHours  Float    @default(2.0) // Hours until deadline to trigger emergency
  notificationsEnabled     Boolean  @default(true)
  theme                    AppTheme @default(DARK)
  updatedAt                DateTime @updatedAt

  @@map("user_settings")
}
