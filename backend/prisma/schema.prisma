// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime queries: Connection Pooler (Transaction Mode, port 6543)
  url       = env("DATABASE_URL")
  // Migrations only: Direct Connection (port 5432)
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum TaskStatus {
  DRAFT
  ANALYZING
  ACTIVE
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  ABANDONED
}

enum GoalType {
  SHORT_TERM
  LONG_TERM
}

enum HabitFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum CalendarEventType {
  TASK_BLOCK
  HABIT_BLOCK
  MEETING
  FREE_TIME
  BUFFER
  BREAK
}

enum InsightType {
  PRODUCTIVITY_PATTERN
  WEEKLY_SUMMARY
  MONTHLY_SUMMARY
  FOCUS_SCORE
  DELAY_ANALYSIS
  COACHING_TIP
}

enum AppTheme {
  DARK
  LIGHT
  SYSTEM
}

// ─────────────────────────────────────────────────────────────
// Task Model
// ─────────────────────────────────────────────────────────────

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  deadline    DateTime?
  estimatedHours Float?
  tags        String[]
  status      TaskStatus @default(DRAFT)

  // ── AI-generated fields ────────────────────────────────────
  aiPriority          Int?             // 1–10
  riskLevel           RiskLevel?
  difficulty          DifficultyLevel?
  estimatedCompletion String?          // Human-readable, e.g. "3 hours"
  executionPlan       String?          // Step-by-step strategy
  productivityAdvice  String?
  nextImmediateStep   String?
  potentialBlockers   Json?            // String[]
  dependencies        Json?            // String[]
  subtasks            Json?            // Subtask[]
  analysisMetadata    Json?            // Reserved for future AI metadata

  // ── Phase 2 dynamic prioritization fields ─────────────────
  priorityScore       Int?             // Dynamic priority score (1-100)
  priorityLabel       String?          // Dynamic label: Critical, High, Medium, Low
  priorityReason      String?          // Justification reason
  confidence          Float?           // Confidence score (0-1)
  lastPrioritizedAt   DateTime?        // Last prioritized timestamp

  // ── Phase 3 Companion Enhancements ────────────────────────
  riskScore           Int?             // 0-100 risk score
  completionProb      Float?           // Completion probability (0-1)
  missProbability     Float?           // Miss probability (0-1)
  timeDeficit         Float?           // Time deficit in hours
  recoveryPlan        Json?            // Action recovery suggestions
  lastRiskAnalysisAt  DateTime?        // Risk analysis timestamp

  // ── Analysis tracking ─────────────────────────────────────
  isAnalyzed    Boolean   @default(false)
  analyzedAt    DateTime?
  analysisError String?

  // ── Timestamps ────────────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tasks")
}

// ─────────────────────────────────────────────────────────────
// Daily Plan Model
// ─────────────────────────────────────────────────────────────

model DailyPlan {
  id                      String   @id @default(cuid())
  date                    String   @unique // format: YYYY-MM-DD
  schedule                Json     // Today's schedule time blocks
  suggestedOrder          Json     // string[] of task IDs in recommended order
  recommendedBreaks       Json     // string[] of recommended breaks
  expectedFinishTime      String   // expected end of workday
  tasksToPostpone         Json     // string[] of task IDs/titles to postpone
  mostImportantTask       String   // taskId or title of the MIT
  recommendedFocusSession String   // description of focus blocks
  quickWins               Json     // string[] of task IDs/titles
  highEffortWork          Json     // string[] of task IDs/titles
  deepWorkBlocks          Json     // string[] of work blocks
  isFallback              Boolean  @default(false) // Offline Mode indicator
  isStale                 Boolean  @default(false) // cache staleness status
  generatedAt             DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("daily_plans")
}

