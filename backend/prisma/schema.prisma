model Notification {
  id          String   @id @default(cuid())
  taskId      String?
  type        String
  message     String
  read        Boolean  @default(false)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime @default(now())
  @@map("notifications")
}

model PlannerMetric {
  id          String   @id @default(cuid())
  metric      String   // GEMINI_CALL, OFFLINE_FALLBACK, EMERGENCY_TRIGGER
  status      String   // SUCCESS, FAILURE
  details     String?  // error details or triggers
  createdAt   DateTime @default(now())
  @@map("planner_metrics")
}

